generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeliveryStatus {
  pendiente
  en_curso
  completada
  cancelada
}

model Category {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  rank             Int      @unique
  minDeliveries    Int
  minRating        Decimal  @db.Decimal(3, 2)
  commissionPct    Decimal  @db.Decimal(5, 2)
  riders           Rider[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Rider {
  id           Int        @id
  name         String
  email        String     @unique
  phone        String
  zone         String
  joinedAt     DateTime
  categoryId   Int
  category     Category   @relation(fields: [categoryId], references: [id])
  deliveries   Delivery[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([zone])
  @@index([categoryId])
}

model Delivery {
  id             Int            @id @default(autoincrement())
  riderId        Int
  description    String
  amount         Decimal        @db.Decimal(10, 2)
  status         DeliveryStatus @default(pendiente)
  customerRating Decimal?       @db.Decimal(3, 2)
  createdAt      DateTime
  completedAt    DateTime?
  canceledAt     DateTime?
  updatedAt      DateTime       @updatedAt
  rider          Rider          @relation(fields: [riderId], references: [id])

  @@index([riderId])
  @@index([status])
  @@index([createdAt])
  @@index([completedAt])
}
